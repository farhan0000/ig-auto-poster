# OpenAI ----------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxx
# Models (override if you like)
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Instagram Graph API ---------------------------------------------
# IG Business/Creator account ID (numeric, NOT the @handle).
# Get it from: GET https://graph.facebook.com/v21.0/me/accounts?access_token=...
# then for the page: GET /<PAGE_ID>?fields=instagram_business_account
IG_USER_ID=178414xxxxxxxxxx

# Long-lived Page access token (60 days). See README for refresh.
IG_ACCESS_TOKEN=EAAG...

# Public image hosting --------------------------------------------
# When running on GitHub Actions we commit the image back to the repo
# and serve it from raw.githubusercontent.com. Set these to match your
# fork. Locally you can leave blank to skip publishing.
GH_RAW_BASE=https://raw.githubusercontent.com/YOUR_USERNAME/ig-auto-poster/main

# Behavior --------------------------------------------------------
# If true, generate everything but DO NOT call Instagram (safe testing).
DRY_RUN=false
