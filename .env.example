# OpenAI ----------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_TEXT_MODEL=gpt-4o-mini       # cheap; only used for the script + caption
OPENAI_IMAGE_MODEL=gpt-image-1      # ~$0.04 / image at 1024x1536
OPENAI_IMAGE_SIZE=1024x1536         # 9:16 portrait closest to TikTok native
OPENAI_TTS_MODEL=tts-1-hd           # $0.030 per 1k chars; ~$0.015 / 60-word script
OPENAI_TTS_VOICE=nova               # alloy, echo, fable, onyx, nova, shimmer
                                    # nova = friendly female, best for tech engagement

# TikTok Content Posting API --------------------------------------
# Get these by running:  python scripts/tiktok_oauth.py
# (See README for the developer-portal setup steps.)
TIKTOK_ACCESS_TOKEN=                 # ~24h lifetime; refresh via the helper script
TIKTOK_DIRECT_PUBLISH=false          # leave false until your app is approved
                                     # for direct publish; until then videos go
                                     # to the user's TikTok Drafts inbox.

# Behavior --------------------------------------------------------
DRY_RUN=false                        # if true, generate but DO NOT upload
