# OpenAI ----------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxx
# Models (override if you like)
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Instagram Graph API (Instagram Login flow — no Facebook Page needed) ----
# Numeric IG user ID for your Business/Creator account. NOT the @handle.
# Get it from: GET https://graph.instagram.com/v21.0/me?access_token=...
IG_USER_ID=1784140000000000

# Long-lived IG user access token (60 days). Refresh before expiry by
# hitting GET https://graph.instagram.com/refresh_access_token with the
# current token. See README.
IG_ACCESS_TOKEN=IGQVJ...

# OPTIONAL: API base URL. Defaults to Instagram-Login flow. Set this only
# if you want to use the older Facebook-Login flow with a Page token:
#   IG_API_BASE=https://graph.facebook.com/v21.0
IG_API_BASE=

# Public image hosting --------------------------------------------
# When running on GitHub Actions we commit the image back to the repo
# and serve it from raw.githubusercontent.com. Set these to match your
# fork. Locally you can leave blank to skip publishing.
GH_RAW_BASE=https://raw.githubusercontent.com/YOUR_USERNAME/ig-auto-poster/main

# Behavior --------------------------------------------------------
# If true, generate everything but DO NOT call Instagram (safe testing).
DRY_RUN=false
